# ── Required (no defaults) ────────────────────────────────────────────

# JWT signing key — generate a random string:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_a_random_64_char_hex_string

# Credential encryption key — must be a 32-byte URL-safe base64 Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=changeme_generate_with_fernet_generate_key

# Admin password hash — Argon2 hash of your admin password:
#   pip install pwdlib pwdlib[argon2]
#   python -c "from pwdlib import PasswordHash; print(PasswordHash.recommended().hash('your-admin-password'))"
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=...

# ── Optional ──────────────────────────────────────────────────────────

# Admin username (default: admin)
# ADMIN_USERNAME=admin

# Token expiration (hours, default: 24)
# JWT_EXPIRE_HOURS=24

# Database path (SQLite, default: sqlite:///./data/dashboard.db)
# DATABASE_URL=sqlite:///./data/dashboard.db

# Host config YAML path (default: /app/data/hosts.yaml)
# HOST_CONFIG_PATH=/app/data/hosts.yaml

# Poll intervals (seconds)
# METRICS_POLL_INTERVAL=3
# DOCKER_POLL_INTERVAL=10
# UPDATE_CHECK_INTERVAL=21600

# Log level
# LOG_LEVEL=info
