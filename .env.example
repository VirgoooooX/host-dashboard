# ── Required (no defaults) ────────────────────────────────────────────

# JWT signing key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_a_random_64_char_hex_string

# Credential encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=changeme_generate_with_fernet_generate_key

# Admin password hash: pip install pwdlib[argon2]; python -c "from pwdlib import PasswordHash; print(PasswordHash.recommended().hash('your-password'))"
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=...

# ── Optional ──────────────────────────────────────────────────────────

# ADMIN_USERNAME=admin
# JWT_EXPIRE_HOURS=24
# LOG_LEVEL=info
# METRICS_POLL_INTERVAL=3
# DOCKER_POLL_INTERVAL=10
